{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ObsShogi",
  "version": "0.1.0",
  "identifier": "com.rioh1118.obs-shogi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "obs-shogi",
        "width": 1600,
        "height": 960,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1NUREQzYwMEQ1Nzk4NUIKUldSYm1GY05ZTnhkSlpoM1VmS2JMTUhiK0ZSQjlCNHBwdEk1Z1R2MDBVOC9GUnlSWXJ3ZXFWaWkK",
      "endpoints": [
        "https://github.com/Rioh1118/obs-shogi/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
